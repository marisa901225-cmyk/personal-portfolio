# === 서버 및 보안 ===
API_TOKEN=your_secure_api_token
SECRET_KEY=your_secret_key_for_jwt
ALLOWED_HOSTS=*

# === 데이터베이스 ===
# SQLite (기본값)
DATABASE_URL=sqlite:///./portfolio.db

# === 텔레그램 봇 ===
# 권장 키 (사용처: backend/integrations/telegram.py, backend/routers/telegram_webhook.py)
ALARM_TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
ALARM_TELEGRAM_CHAT_ID=123456789

# 하위 호환용 별칭 (선택 사항)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# 텔레그램 웹훅 시크릿 토큰 (권장)
# 텔레그램에서 setWebhook의 `secret_token` 옵션으로 설정하세요.
X_TELEGRAM_BOT_API_SECRET_TOKEN=your_webhook_secret_token

# === 로컬 LLM ===
# GGUF 모델 파일 경로
LOCAL_LLM_MODEL_PATH=backend/data/gemma-3-4b-it-q4_k_m.gguf
# LLM에 사용할 CPU 스레드 수 (기본값: 4, 코딩 안전성을 위해 2 권장)
LOCAL_LLM_THREADS=2

# === 원격 LLM (OpenAI 호환 llama-server) ===
# 설정 시, 백엔드는 로컬 GGUF 모델 로드 대신 원격 서버를 호출합니다.
LLM_BASE_URL=http://llama-server:8080
LLM_TIMEOUT=120
LLM_REMOTE_DEFAULT_MODEL=EXAONE-4.0-1.2B-BF16.gguf
# 선택 사항 (원격 서버에서 인증이 필요한 경우)
LLM_API_KEY=

# === 게임 뉴스 API (선택 사항) ===
# PandaScore (e스포츠 일정) - https://pandascore.co/
PANDASCORE_API_KEY=your_pandascore_key

# Steam Web API - https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key

# 네이버 검색 API (뉴스) - https://developers.naver.com/apps/
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# === 한국투자증권 (KIS) ===
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_CANO=your_account_number_prefix
KIS_ACNT_PRDT_CD=01

# === 디스코드 (선택 사항) ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

#로컬 LLM 컨텍스트 크기
MEMORY_CHAT_CONTEXT_TOKENS=4096
MEMORY_CHAT_SUMMARY_TRIGGER_TOKENS=2700
MEMORY_CHAT_SUMMARY_KEEP_MESSAGES=6
MEMORY_CHAT_SUMMARY_MAX_TOKENS=256
MEMORY_CHAT_SUMMARY_SESSION_TTL_SEC=21600