# Safe runtime config only.
# Copy to backend/.env inside the repo.
# Keep secrets in a separate file outside the repo, e.g. ~/ai-models/myasset.secrets.env.

# =========================
# Core / Runtime
# =========================
DATABASE_URL=sqlite:////app/backend/storage/db/portfolio.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOW_NO_AUTH=0
LOG_LEVEL=INFO
MAX_UPLOAD_MB=20

# Auth behavior
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
NAVER_REDIRECT_URI=http://localhost:5173/auth/callback
NAVER_ALLOWED_IDS=

# Rate limiting
RATE_LIMIT_DEFAULT=120
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_CLEANUP_SEC=600
RATE_LIMIT_ALLOWLIST=127.0.0.1,::1

# =========================
# LLM / AI Routing
# =========================
LLM_BASE_URL=http://openvino-server:8082
LLM_TIMEOUT=120
LLM_LIGHT_BASE_URL=http://localhost:8081
LLM_LIGHT_MODEL_ID=Qwen3-0.6B-Q8_0
NEWS_LLM_BASE_URL=http://openvino-server:8082
ALARM_SUMMARY_LLM_BASE_URL=http://openvino-server:8082
ALARM_RANDOM_LLM_BASE_URL=http://llama-server-vulkan-huihui:8083
AI_REPORT_BASE_URL=https://api.openai.com/v1
AI_REPORT_MODEL=gpt-5.2
AI_REPORT_MODEL_YEARLY=gpt-5.2-pro
AI_REPORT_FALLBACK_MODEL=gpt-5.4-mini
AI_REPORT_TEMPERATURE=0.3
AI_REPORT_MAX_TOKENS=8000
AI_REPORT_TIMEOUT_SEC=900
MORNING_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MORNING_OPENROUTER_MODEL=google/gemini-3-flash-preview
MORNING_ALLOW_PAID_FALLBACK=0
LLM_REMOTE_URL=http://localhost:8080
LLM_REMOTE_DEFAULT_MODEL=Josiefied-Qwen3-8B-int8
LLM_REMOTE_MODEL_DIR=/data
LLM_REMOTE_MODEL_PATH_FILE=
DEBUG_LLM_DRAFT=0

# =========================
# Backup / Paths
# =========================
EXTERNAL_BACKUP_PATH=/mnt/one-touch/backups
KIS_ENABLED=auto
KIS_CONFIG_DIR=/root/KIS/config
KIS_PROD=https://openapi.koreainvestment.com:9443
KIS_OPS=ws://ops.koreainvestment.com:21000
KIS_VPS=https://openapivts.koreainvestment.com:29443
KIS_VOPS=ws://ops.koreainvestment.com:31000
# Current prod limit is 20/sec.
# Use backend/scripts/shell/kis_rate_limit_restore_once.sh to cut over to 18/sec on 2026-04-20.
# When fan-out happens concurrently, stagger callers by about 100-150ms at the call site.
KIS_REST_RATE_LIMIT_PER_SEC=20
KIS_REST_RATE_WINDOW_SEC=1.0

# =========================
# Trading Engine
# =========================
TRADING_ENGINE_ENABLED=0
# Example: backend.integrations.kis.trading_adapter:create_trading_api
TRADING_ENGINE_API_FACTORY=
TRADING_ENGINE_SCHEDULE_INTERVAL_MIN=2
TRADING_ENGINE_INCLUDE_ETF=1
TRADING_ENGINE_MONITOR_SEC=240
TRADING_ENGINE_STATE_PATH=backend/storage/trading_engine/state.json
TRADING_ENGINE_OUTPUT_DIR=backend/storage/trading_engine/output
TRADING_ENGINE_RUNLOG_PATH=backend/storage/trading_engine/runlog_current.log
TRADING_ENGINE_SWING_CASH_RATIO=0.80
TRADING_ENGINE_DAY_CASH_RATIO=0.20
TRADING_ENGINE_DAY_INTRADAY_STRENGTH_WEIGHT=1.8
TRADING_ENGINE_DAY_MOMENTUM_CHASE_MAX_CHANGE_PCT=26.0
TRADING_ENGINE_DAY_MOMENTUM_CHASE_MIN_INTRADAY_SCORE=3.0
TRADING_ENGINE_DAY_MOMENTUM_PULLBACK_MIN_DAY_CHANGE_PCT=12.0
TRADING_ENGINE_DAY_MOMENTUM_PULLBACK_MIN_WINDOW_CHANGE_PCT=-1.0
TRADING_ENGINE_DAY_MOMENTUM_PULLBACK_MIN_LAST_BAR_CHANGE_PCT=-0.25
TRADING_ENGINE_DAY_MOMENTUM_PULLBACK_MAX_RETRACE_FROM_HIGH_PCT=-1.8
TRADING_ENGINE_USE_REALIZED_PROFIT_BUFFER=1
TRADING_ENGINE_SWING_ENTRY_ORDER_TYPE=best
TRADING_ENGINE_DAY_ENTRY_ORDER_TYPE=best
TRADING_ENGINE_RISK_OFF_PARKING_CODE=
TRADING_ENGINE_RISK_OFF_PARKING_ORDER_TYPE=market

# =========================
# Misc
# =========================
ALARM_DEDUP_WINDOW_SECONDS=600
ALARM_SILENCE_ACTIVE_WINDOW=0
SPAM_NB_THRESHOLD=0.85
TELEGRAM_MAX_MESSAGE_LEN=4096
TAILSCALE_TAILNET_DOMAIN=
ELECTION_REGION_MODE=
ELECTION_REGION_ALLOWLIST=
CATCHPHRASE_SAVE_PATH=backend/data/esports_catchphrase.txt
